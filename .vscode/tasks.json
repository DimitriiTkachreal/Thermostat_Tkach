{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build: firmware",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/Software/core"
            },
            "command": "cxstm8 +mods0 -i\"../bsp\" -i\"../mcu\" -i\"../drivers\" -i\"../app\" main.c stm8_interrupt_vector.c ../mcu/gpio.c ../mcu/clock.c ../mcu/adc.c ../mcu/eeprom.c ../mcu/timer.c ../mcu/uart.c ../drivers/tm1637.c ../drivers/ntc.c ../drivers/buttons.c ../app/settings.c ../app/ui.c ../app/thermostat.c ; clnk -o main.sm8 Linker.lkf ; chex -o \"../build/firmware.s19\" main.sm8",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "flash: stvp",
            "type": "process",
            "command": "C:\\Program Files (x86)\\STMicroelectronics\\st_toolset\\stvp\\STVP_CmdLine.exe",
            "args": [
                "-BoardName=ST-LINK",
                "-Port=USB",
                "-ProgMode=SWIM",
                "-Device=STM8S103F3",
                "-no_loop",
                "-no_log",
                "-verif",
                "-FileProg=${workspaceFolder}\\Software\\build\\firmware.s19"
            ],
            "dependsOn": "build: firmware",
            "problemMatcher": []
        }
    ]
}